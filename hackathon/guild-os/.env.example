# GuildOS — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
#
# On-chain network settings (contract addresses, RPC URL template, explorer
# links, DELIVERY_SCHEMA_UID) are NOT here anymore — they live in
# config/networks.json, keyed by CHAIN_ID. This file only holds CHAIN_ID
# itself (the selector) and secrets that must never be committed to git.
# See src/shared/network_config.py for the loader.

# ── Network selector ────────────────────────────────────────────────────────
# 84532 = Base Sepolia (isolated component testing)
# 8453  = Base (deployment / full integration — required for submission evidence)
# Resolves into config/networks.json — never read a contract address or RPC
# URL from an env var anywhere else in this project.
CHAIN_ID=8453

# ── RPC (secret — injected into config/networks.json's rpc_url_template) ──────
ALCHEMY_API_KEY=your_alchemy_api_key_here

# ── Wallet provider (CAW default; ZeroDev/Turnkey swappable, same scoping) ────
WALLET_PROVIDER=caw

# ── Agent wallet addresses ────────────────────────────────────────────────────
ORCHESTRATOR_WALLET_ADDRESS=0x_orchestrator_wallet_address
SPECIALIST_WALLET_ADDRESS=0x_specialist_wallet_address

# ── AgentFightClub (skip to use DAOhaus SDK fallback) ─────────────────────────
CLAWBANK_BASE_URL=https://app.clawbank.co
CLAWBANK_API_KEY=

# ── Ports ─────────────────────────────────────────────────────────────────────
ORCHESTRATOR_A2A_PORT=10000
SPECIALIST_A2A_PORT=10001

# ── Moved to config/networks.json (do not set here) ───────────────────────────
# EAS_CONTRACT, EAS_SCHEMA_REGISTRY, DELIVERY_SCHEMA_UID, ERC8004_CONTRACT,
# REPUTATION_CONTRACT — all network-specific, all resolved via
# src/shared/network_config.py from the active CHAIN_ID. To register a new
# DELIVERY_SCHEMA_UID, write it into config/networks.json under the relevant
# chain ID, not here.
