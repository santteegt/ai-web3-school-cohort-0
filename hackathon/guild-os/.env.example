# GuildOS — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Network ───────────────────────────────────────────────────────────────────
# 84532 = Base Sepolia (isolated component testing)
# 8453  = Base (deployment / full integration — required for submission evidence)
CHAIN_ID=8453

# ── RPC ───────────────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key_here

# ── Agent signing keys ────────────────────────────────────────────────────────
ORCHESTRATOR_PRIVATE_KEY=0x_orchestrator_private_key
SPECIALIST_PRIVATE_KEY=0x_specialist_private_key

# ── Agent wallet addresses ────────────────────────────────────────────────────
ORCHESTRATOR_WALLET_ADDRESS=0x_orchestrator_wallet_address
SPECIALIST_WALLET_ADDRESS=0x_specialist_wallet_address

# ── Z.AI GLM-5.1 ─────────────────────────────────────────────────────────────
GLM_API_KEY=your_glm_api_key_here

# ── AgentFightClub (skip to use DAOhaus SDK fallback) ─────────────────────────
AGENTFIGHTCLUB_API_KEY=

# ── EAS — Ethereum Attestation Service ───────────────────────────────────────
# Contracts are identical on Base and Base Sepolia (pre-deployed by EAS team)
EAS_CONTRACT=0x4200000000000000000000000000000000000021
EAS_SCHEMA_REGISTRY=0x4200000000000000000000000000000000000020
# Register the GuildOS delivery schema ONCE before Step 8, then paste the UID here:
#   schema: "bytes32 deliverableHash, string taskType, address guildContract, uint256 paymentAmount"
#   resolver: 0x0000000000000000000000000000000000000000
#   revocable: false
DELIVERY_SCHEMA_UID=

# ── ERC-8004 (defaults point to deployed registry — change only if it moves) ──
ERC8004_CONTRACT=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_CONTRACT=0x8004B663056A597Dffe9eCcC1965A193B7388713

# ── Ports ─────────────────────────────────────────────────────────────────────
ORCHESTRATOR_A2A_PORT=10000
SPECIALIST_A2A_PORT=10001
