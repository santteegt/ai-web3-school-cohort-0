# ── Cobo Agentic Wallet (CAW) ─────────────────────────────────────────────────
# Run `caw onboard` to get these three values
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_ID=
AGENT_WALLET_ADDRESS=

# Cobo chain ID for Base Sepolia — verify via `GET /metadata/chains` after onboarding
# Common values: TBASE_SETH (Base Sepolia), SETH (Ethereum Sepolia)
CAW_CHAIN_ID=TBASE_SETH

# ── Stub server ────────────────────────────────────────────────────────────────
STUB_SERVER_PORT=3402
# Receiver address for x402 payments — must be funded with USDC on Base Sepolia
# (use `caw faucet deposit` or https://faucet.circle.com for testnet USDC)
STUB_SERVER_ADDRESS=

# ── Pact limits (USD-denominated) ─────────────────────────────────────────────
PRICE_PER_CALL_USD=0.001      # $0.001 per inference call
PACT_PER_CALL_CEILING_USD=0.01 # reject if x402 asks more than this per call
PACT_SESSION_BUDGET_USD=0.10   # total rolling-24h spend cap
PACT_WINDOW_SECONDS=3600       # pact auto-revokes after 1 hour

# ── Audit trail ───────────────────────────────────────────────────────────────
BASESCAN_URL=https://sepolia.basescan.org

# ── Loop control ──────────────────────────────────────────────────────────────
CALL_COUNT=3  # number of paid calls to run per session

# ── Local Signer ──────────────────────────────────────────────────────────────
USE_LOCAL_SIGNER=false
LOCAL_SIGNER_PRIVATE_KEY=
