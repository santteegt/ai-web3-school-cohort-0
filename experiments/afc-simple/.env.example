# Agent Fight Club — ClawBank convenience path PoC
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# Required — your ClawBank instance
CLAWBANK_BASE_URL=https://app.clawbank.co
CLAWBANK_TOKEN=your_bearer_token_here

# Optional — target DAO (0x address on Base mainnet)
# If unset, the script will call list-daos / my-daos to discover one.
AFC_DAO=0x

# Optional — recipient address for write demos
# AFC_SPECIALIST is used for mint-shares; AFC_PAYMENT_TO for payment proposals.
# If AFC_PAYMENT_TO is unset it defaults to AFC_SPECIALIST.
AFC_SPECIALIST=0x
AFC_PAYMENT_TO=0x

# Summon (--summon flag)
# Founding member address. If unset, resolved automatically from fightclub_account (signer wallet).
AFC_MEMBER=0x
# All other summon params (daoName, tokenName, periods, etc.) live in summon_params.json
