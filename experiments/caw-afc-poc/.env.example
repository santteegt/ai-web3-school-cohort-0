# ===== Cobo Agentic Wallet =====
# Run `caw wallet current --show-api-key` to get these values
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_ID=

# Orchestrator CAW wallet address (used as initial DAO member)
ORCHESTRATOR_CAW_ADDRESS=0x...

# ===== Moloch / AgentFightClub =====
# NOTE: RPC must have access to `eth_getTransactionReceipt` 
# otherwise it will return HTTP 403 (Recommended: Get an Alchemy RPC node)
MOLOCH_RPC_URL=https://mainnet.base.org
MOLOCH_CHAIN_ID=8453

# ===== PoC Configuration =====
# set to an existing DAO on Base if you want to skip deployment
DAO_ADDRESS=
DAO_NAME=GuildOS-POC
TOKEN_NAME=GUILDPOC
TOKEN_SYMBOL=GUILDPOC
SPECIALIST_WALLET_ADDRESS=0x...  # Specialist wallet address to receive membership
VOTING_PERIOD_SECONDS=60
GRACE_PERIOD_SECONDS=30

# ===== Dev =====
USE_MOCK_CAW=true   # set to false for real on-chain execution
SKIP_DAO_DEPLOYMENT=false 
